            "timeout": 5,
            "cameras": [],
        },
        "auth": {
            "user": "",
            "password": "",
            "inject_credentials": True,
            "timeout": 10,
        },
        "proxy": {
            # proxy: nvrd starts go2rtc and routes record/play through it.
            # direct: record/play hit the camera directly (no go2rtc needed).
            "mode": "proxy",
            # Where go2rtc binds. Default is loopback-only — bump to 0.0.0.0
            # if you want Frigate / Home Assistant on another host to tap in.
            "bind": "127.0.0.1",
            "rtsp_port": 8554,
            "api_port": 1984,
            # How long to wait (seconds) for the go2rtc API to come online
            # after we start it.
            "ready_timeout": 15,
        },
        "playback": {
