            "player": "auto",
            "transport": "tcp",
            "no_audio": True,
        },
        "monitor": {
            "interval": 30,
            "verify_recording": True,
            "stale_grace": 60,
            # Restart-loop backoff: after a rtsp-record exit we wait
            # `restart_backoff_initial` seconds before respawning, doubling
            # each consecutive failure up to `restart_backoff_max`. A clean
            # run that produces at least one segment resets it. Without this,
            # a permanently-broken cam (e.g. wrong codec, bad creds) makes
            # nvrd hammer the camera every ~30 s indefinitely.
            "restart_backoff_initial": 5,
            "restart_backoff_max": 60,
        },
        "logging": {
            "level": "info",
            "file": None,
        },
    }


# Backwards-compat shim for tests / downstream code that import the constant.
DEFAULT_CONFIG: Dict[str, Any] = _default_config()


# Matches the userinfo (user[:pass]) part of an RTSP/HTTP/HTTPS URL.
_USERINFO_RE = re.compile(r"(?P<scheme>\b(?:rtsp|rtsps|http|https)://)[^/@\s]+@")


def _redact_url(s: str) -> str:
    """Replace userinfo in URLs with `***` for safe logging.

    `rtsp://admin:hunter2@192.168.1.4/stream` → `rtsp://***@192.168.1.4/stream`

    Used everywhere we might emit a URL we got from `onvif-rtsp` (which can
    embed credentials when --inject-credentials is on). Without this, a
    DEBUG-level log file would persist passwords forever.
    """
    return _USERINFO_RE.sub(r"\g<scheme>***@", s)


GO2RTC_INSTALL_HINT = (
    "go2rtc not in PATH. It's a single static binary — download the latest "
    "release for your arch from https://github.com/AlexxIT/go2rtc/releases "
    "and drop it into ~/.local/bin/ (chmod +x). "
    "Alternatively, set proxy.mode to 'direct' in the config to skip go2rtc."
)


def _deep_merge(dst: Dict[str, Any], src: Dict[str, Any]) -> Dict[str, Any]:
    for k, v in src.items():
        if isinstance(v, dict) and isinstance(dst.get(k), dict):
            _deep_merge(dst[k], v)
        else:
            dst[k] = v
    return dst


def load_config(path: Optional[str]) -> Dict[str, Any]:
    """Load a YAML config from `path`, merge over the defaults. If path is
    None, returns just the defaults — useful for `--auto` no-config mode.

    Also warns on stderr if the file is world-/group-readable: the config
    typically contains `auth.password`, and a 644 file means any local user
    can read the camera credentials.
    """
    cfg = _default_config()
    if not path:
        return cfg
    try:
        import yaml  # type: ignore
    except ImportError:
        raise SystemExit(
            f"{PROG}: PyYAML not installed (install with: pip install pyyaml)"
        )
    p = Path(os.path.expanduser(path))
    if not p.is_file():
        raise SystemExit(f"{PROG}: config file not found: {path}")
    _warn_if_config_world_readable(p)
    with open(p, "r", encoding="utf-8") as f:
        loaded = yaml.safe_load(f) or {}
    if not isinstance(loaded, dict):
        raise SystemExit(f"{PROG}: config root must be a mapping")
    _deep_merge(cfg, loaded)
    _validate_config(cfg)
    return cfg


def _warn_if_config_world_readable(p: Path) -> None:
    """Print a stderr warning if the config file's permission bits include
    any world or group access. Typical safe mode is 0600.

    On non-POSIX filesystems (e.g. CIFS-mounted, FAT) the mode bits are
    meaningless, so we silently skip rather than nag the user uselessly.
    """
    try:
        st = os.stat(p)
    except OSError:
        return
    # Skip the warning when the host filesystem doesn't carry meaningful
    # POSIX modes (mode 0 means none of these bits make sense).
    if st.st_mode & 0o777 == 0:
        return
    if st.st_mode & 0o077:
        print(
            f"{PROG}: WARNING: {p} is group/world-readable (mode "
            f"{st.st_mode & 0o777:#o}); it likely contains credentials. "
            f"Run: chmod 600 {p}",
            file=sys.stderr,
        )


def _validate_config(cfg: Dict[str, Any]) -> None:
    sched = cfg["schedule"]
    if not isinstance(sched["segment_duration"], int) or sched["segment_duration"] <= 0:
        raise SystemExit(f"{PROG}: schedule.segment_duration must be a positive integer")
    rotate = sched["rotate_at"]
    if not (isinstance(rotate, str) and re.fullmatch(r"\d{1,2}:\d{2}", rotate)):
        raise SystemExit(f"{PROG}: schedule.rotate_at must be HH:MM (e.g. \"00:00\")")
    h, m = (int(x) for x in rotate.split(":"))
    if not (0 <= h < 24 and 0 <= m < 60):
        raise SystemExit(f"{PROG}: schedule.rotate_at out of range: {rotate!r}")

    disc = cfg["discovery"]
    if disc["mode"] not in ("auto", "static"):
        raise SystemExit(f"{PROG}: discovery.mode must be 'auto' or 'static'")
    if disc["mode"] == "static" and not disc.get("cameras"):
        raise SystemExit(f"{PROG}: discovery.mode=static requires discovery.cameras")

    pb = cfg["playback"]
    if pb["player"] not in ("auto", "mpv", "ffplay"):
        raise SystemExit(f"{PROG}: playback.player must be auto|mpv|ffplay")
    if pb["transport"] not in ("tcp", "udp"):
        raise SystemExit(f"{PROG}: playback.transport must be tcp|udp")

    proxy = cfg["proxy"]
    if proxy["mode"] not in ("proxy", "direct"):
        raise SystemExit(f"{PROG}: proxy.mode must be 'proxy' or 'direct'")
    for key in ("rtsp_port", "api_port"):
        port = proxy[key]
        if not isinstance(port, int) or not (1 <= port <= 65535):
            raise SystemExit(f"{PROG}: proxy.{key} must be a TCP port 1..65535")
    if proxy["rtsp_port"] == proxy["api_port"]:
        raise SystemExit(f"{PROG}: proxy.rtsp_port and proxy.api_port must differ")


# ---------------------------------------------------------------------------
# Camera modeling
# ---------------------------------------------------------------------------

@dataclasses.dataclass
class Camera:
    name: str
    device_url: str
    user: str
    password: str
    inject_credentials: bool
    rtsp_url: Optional[str] = None  # populated by resolve_rtsp_url

    def storage_root(self, base: str) -> Path:
        return Path(base) / self.name


def _safe_name_from_url(url: str) -> str:
    """Derive a safe directory name from a device URL. e.g.
    http://192.168.0.73:8899/onvif/device_service -> cam-192-168-0-73"""
    p = urlparse(url)
    host = (p.hostname or "unknown").replace(":", "-").replace(".", "-")
    return f"cam-{host}"


# ---------------------------------------------------------------------------
# go2rtc supervisor
# ---------------------------------------------------------------------------

# Characters whose presence requires us to wrap a YAML scalar in double
# quotes. Matches the rules in go2rtc-gen.
_YAML_NEEDS_QUOTING = set('#&*!|>%@`,[]{}')


def _yaml_value(s: str) -> str:
    if (s == "" or s != s.strip() or s.startswith(":")
            or ": " in s or any(c in _YAML_NEEDS_QUOTING for c in s)):
        return '"' + s.replace("\\", "\\\\").replace('"', '\\"') + '"'
    return s


def render_go2rtc_yaml(cams: List[Camera], bind: str,
                       rtsp_port: int, api_port: int) -> str:
    """Same wire format as go2rtc-gen, with explicit listen addresses and
    one stream per camera keyed by `cam.name`."""
    api_listen  = f"{bind}:{api_port}"
    rtsp_listen = f"{bind}:{rtsp_port}"
    out = ["api:",
           f"  listen: {_yaml_value(api_listen)}",
           "rtsp:",
           f"  listen: {_yaml_value(rtsp_listen)}",
           "streams:"]
    for cam in cams:
        url = cam.rtsp_url or ""
        out.append(f"  {cam.name}: {_yaml_value(url)}")
    return "\n".join(out) + "\n"


class Go2rtcSupervisor:
    """Spawns and monitors a single `go2rtc -config <file>` subprocess.

    Cams are replaceable via `set_cams()` so the orchestrator can re-resolve
    URLs (e.g. after a camera DHCP change) and then call `restart()` to pick
    them up — without that, a `restart()` after a network blip would just
    re-launch go2rtc against the same stale URLs in a loop of death.
    """

    def __init__(self, cams: List[Camera], cfg: Dict[str, Any]):
        self.cams = cams
        self.cfg = cfg["proxy"]
        self.proc: Optional[subprocess.Popen] = None
        self._tmp_path: Optional[str] = None
        self._lock = threading.Lock()

    def set_cams(self, cams: List[Camera]) -> None:
        """Replace the cam list used on the next start()/restart()."""
        self.cams = cams

    def local_url_for(self, cam: Camera) -> str:
        return f"rtsp://{self.cfg['bind']}:{self.cfg['rtsp_port']}/{cam.name}"

    def start(self) -> None:
        import tempfile
        yaml_text = render_go2rtc_yaml(
            self.cams, self.cfg["bind"],
            self.cfg["rtsp_port"], self.cfg["api_port"],
        )
        f = tempfile.NamedTemporaryFile(
            mode="w", encoding="utf-8", suffix=".yaml",
            prefix="nvrd-go2rtc-", delete=False,
        )
        f.write(yaml_text); f.close()
        # mkstemp (used internally by NamedTemporaryFile) opens with mode
        # 0600. Re-assert it explicitly in case the umask was permissive.
        try:
            os.chmod(f.name, 0o600)
        except OSError:
            pass
        self._tmp_path = f.name
        logger.info("starting go2rtc (config: %s)", self._tmp_path)
        # The YAML body contains the cameras' RTSP URLs which carry creds
        # when --inject-credentials is on. Redact before logging — DEBUG
        # output often ends up in long-lived log files / journald.
        logger.debug("go2rtc.yaml:\n%s", _redact_url(yaml_text))
        self.proc = subprocess.Popen(
            ["go2rtc", "-config", self._tmp_path],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )

    def wait_ready(self) -> bool:
        """Poll go2rtc's API until it returns 200 or the timeout elapses."""
        import urllib.error
        import urllib.request
        url = f"http://{self.cfg['bind']}:{self.cfg['api_port']}/api/streams"
        deadline = time.monotonic() + float(self.cfg["ready_timeout"])
        last_err = ""
        while time.monotonic() < deadline:
            if self.proc and self.proc.poll() is not None:
                logger.error("go2rtc exited before becoming ready (rc=%s)",
                             self.proc.returncode)
                return False
            try:
                with urllib.request.urlopen(url, timeout=1.0) as r:
                    if 200 <= r.status < 300:
                        logger.info("go2rtc API up at %s", url)
                        return True
                    last_err = f"HTTP {r.status}"
            except (urllib.error.URLError, OSError) as e:
                last_err = str(e)
            time.sleep(0.3)
        logger.error("go2rtc did not become ready in %ss: %s",
                     self.cfg["ready_timeout"], last_err)
        return False

    def is_alive(self) -> bool:
        return self.proc is not None and self.proc.poll() is None

    def restart(self) -> None:
        logger.warning("restarting go2rtc")
        self.stop()
        self.start()
        self.wait_ready()

    def stop(self) -> None:
        with self._lock:
            if self.proc and self.proc.poll() is None:
                logger.info("stopping go2rtc")
                try:
                    self.proc.send_signal(signal.SIGINT)
                except ProcessLookupError:
                    pass
                try:
                    self.proc.wait(timeout=10)
                except subprocess.TimeoutExpired:
                    logger.warning("go2rtc did not exit on SIGINT; killing")
                    self.proc.kill()
                    self.proc.wait()
            self.proc = None
            if self._tmp_path:
                try:
                    os.unlink(self._tmp_path)
                except OSError:
                    pass
                self._tmp_path = None


# ---------------------------------------------------------------------------
# Subprocess helpers (calls into the leaf scripts)
