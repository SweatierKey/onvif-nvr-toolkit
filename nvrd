def _check_leaf_scripts_in_path() -> None:
    missing = [n for n in LEAF_SCRIPTS if not shutil.which(n)]
    if missing:
        raise SystemExit(
            f"{PROG}: leaf script(s) missing from PATH: {', '.join(missing)} "
            "— install them from the toolkit's sibling repos."
        )


def _check_go2rtc_in_path() -> None:
    if not shutil.which("go2rtc"):
        raise SystemExit(f"{PROG}: {GO2RTC_INSTALL_HINT}")


def discover_devices(timeout: int) -> List[str]:
    """Return the list of device service URLs reported by onvif-discover."""
    cmd = ["onvif-discover", "-t", str(timeout)]
    logger.debug("running: %s", " ".join(cmd))
    try:
        cp = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout + 5)
    except FileNotFoundError:
        raise SystemExit(f"{PROG}: onvif-discover not in PATH")
    if cp.returncode != 0:
        raise SystemExit(
            f"{PROG}: onvif-discover failed (rc={cp.returncode}): {cp.stderr.strip()}"
        )
    return [line.strip() for line in cp.stdout.splitlines() if line.strip()]


def resolve_rtsp_url(cam: Camera, timeout: int) -> str:
    """Call onvif-rtsp to resolve the RTSP URL for a camera.

    Credentials are passed through ONVIF_USER/ONVIF_PASSWORD env vars rather
    than --user/--password CLI flags, so they don't appear in
    `/proc/<pid>/cmdline` (visible to any local user via `ps`/`/proc`).
    `onvif-rtsp` 1.1.0+ reads the env vars when no CLI flag is set.
    """
    cmd = ["onvif-rtsp", "-t", str(timeout)]
    env = dict(os.environ)
    if cam.user:
        env["ONVIF_USER"] = cam.user
        env["ONVIF_PASSWORD"] = cam.password
        if cam.inject_credentials:
            cmd.append("--inject-credentials")
    else:
        # Make sure we don't accidentally inherit creds from an outer env
        # (e.g. left over from a previous cam in the loop).
        env.pop("ONVIF_USER", None)
        env.pop("ONVIF_PASSWORD", None)
    cmd.append(cam.device_url)
    logger.debug("resolving rtsp for %s", cam.name)
    cp = subprocess.run(cmd, capture_output=True, text=True,
                        timeout=timeout + 10, env=env)
    if cp.returncode != 0:
        raise RuntimeError(
            f"onvif-rtsp failed for {cam.name}: rc={cp.returncode} {cp.stderr.strip()}"
        )
    url = cp.stdout.strip()
    if not url:
        raise RuntimeError(f"onvif-rtsp returned no URL for {cam.name}")
    return url


def merge_segments(input_files: List[Path], output: Path) -> None:
    """Run footage-merge to produce `output` from `input_files`. Raises on
    failure with a useful message."""
    if not input_files:
        raise RuntimeError("no input segments to merge")
    cmd = ["footage-merge", "-o", str(output)]
    if output.exists():
        cmd.append("-f")
    cmd += [str(p) for p in input_files]
    logger.debug("merging %d segment(s) into %s", len(input_files), output)
    cp = subprocess.run(cmd, capture_output=True, text=True)
    if cp.returncode != 0:
        raise RuntimeError(
            f"footage-merge failed (rc={cp.returncode}): {cp.stderr.strip()}"
        )


# ---------------------------------------------------------------------------
# Per-camera worker
# ---------------------------------------------------------------------------

class CameraWorker(threading.Thread):
    """Owns the rtsp-record (and optionally rtsp-play) subprocesses for one
    camera. Wakes up on rotation_event for end-of-day handling and on
    stop_event for shutdown."""

    def __init__(self, cam: Camera, cfg: Dict[str, Any], stop_event: threading.Event):
        super().__init__(name=f"cam[{cam.name}]", daemon=True)
        self.cam = cam
        self.cfg = cfg
        self.stop_event = stop_event
        self.rotation_event = threading.Event()
        self.record_proc: Optional[subprocess.Popen] = None
        self.play_proc: Optional[subprocess.Popen] = None
        self._current_day: Optional[str] = None
        self._current_dir: Optional[Path] = None
        self._record_stderr_thread: Optional[threading.Thread] = None
        # Restart backoff: tracks consecutive rtsp-record failures so we
        # don't hammer a permanently-broken cam every monitor.interval.
        self._consecutive_failures = 0
        self._next_restart_at = 0.0
        self._record_started_at = 0.0
        # _stop_subprocesses is called both by Orchestrator.run() in its
        # finally and by the worker's own thread on exit. Serialize so we
        # only log/SIGINT once.
        self._shutdown_lock = threading.Lock()
        self._stopped = False

    # ----- public lifecycle -----

    def request_rotation(self) -> None:
        """Ask the worker to rotate at the next chance (called by main loop)."""
        self.rotation_event.set()

    def shutdown(self) -> None:
        """Stop everything cleanly. Idempotent."""
        self._stop_subprocesses()

    # ----- thread body -----

    def run(self) -> None:
        try:
            self._start_recording_for_today()
            if self.cfg["playback"]["enabled"]:
                self._start_playback()

            interval = self.cfg["monitor"]["interval"]
            verify = self.cfg["monitor"]["verify_recording"]
            grace = self.cfg["monitor"]["stale_grace"]
            backoff_initial = self.cfg["monitor"].get("restart_backoff_initial", 5)
            backoff_max = self.cfg["monitor"].get("restart_backoff_max", 60)
            # If a record process survives this long without dying we treat
            # it as "things work" and wipe the consecutive-failures counter.
            STABLE_AFTER = 60.0
            last_size = -1
            last_change = time.monotonic()

            while not self.stop_event.is_set():
                if self.rotation_event.is_set():
                    self.rotation_event.clear()
                    self._do_rotation()
                    last_size = -1; last_change = time.monotonic()

                # Successfully ran for a while → reset the failure counter so
                # a transient blip later doesn't immediately get exponential
                # treatment.
                if (self.record_proc and self.record_proc.poll() is None
                        and self._consecutive_failures > 0
                        and time.monotonic() - self._record_started_at > STABLE_AFTER):
                    self._consecutive_failures = 0
                    self._next_restart_at = 0.0

                if self.record_proc and self.record_proc.poll() is not None:
                    rc = self.record_proc.returncode
                    self._consecutive_failures += 1
                    backoff = min(
                        backoff_initial * (2 ** (self._consecutive_failures - 1)),
                        backoff_max,
                    )
                    self._next_restart_at = time.monotonic() + backoff
                    logger.warning(
                        "[%s] rtsp-record exited (rc=%s, fail=%d); "
                        "restarting in %ds",
                        self.cam.name, rc, self._consecutive_failures, backoff,
                    )
                    # Drain stderr reader before respawning.
                    if self._record_stderr_thread:
                        self._record_stderr_thread.join(timeout=2)
                        self._record_stderr_thread = None
                    self.record_proc = None
                # Honour the backoff: don't respawn until next_restart_at.
                if (self.record_proc is None
                        and time.monotonic() >= self._next_restart_at):
                    self._start_recording_for_today()
                    last_size = -1; last_change = time.monotonic()

                if self.cfg["playback"]["enabled"] and self.play_proc \
                        and self.play_proc.poll() is not None:
                    logger.warning("[%s] rtsp-play exited (rc=%s); restarting",
                                   self.cam.name, self.play_proc.returncode)
                    self._start_playback()

                if verify and self._current_dir and self.record_proc:
                    cur = _latest_segment(self._current_dir)
                    if cur is not None:
                        size = cur.stat().st_size
                        if size != last_size:
                            last_size = size
                            last_change = time.monotonic()
                        elif time.monotonic() - last_change > grace:
                            logger.warning(
                                "[%s] segment %s has not grown in %ds — "
                                "restarting rtsp-record",
                                self.cam.name, cur.name, grace,
                            )
                            self._restart_recording()
                            last_size = -1; last_change = time.monotonic()

                # Sleep in small chunks for responsive shutdown.
                end = time.monotonic() + interval
                while time.monotonic() < end and not self.stop_event.is_set() \
                        and not self.rotation_event.is_set():
                    time.sleep(0.5)
        except Exception:
            logger.exception("[%s] worker crashed", self.cam.name)
        finally:
            self._stop_subprocesses()

    # ----- subprocess management -----

    def _start_recording_for_today(self) -> None:
        today = _dt.date.today().strftime(DATE_FOLDER_FORMAT)
        self._current_day = today
        base = Path(self.cfg["storage"]["base_dir"]).expanduser()
        day_dir = base / self.cam.name / today
        day_dir.mkdir(parents=True, exist_ok=True)
        self._current_dir = day_dir
        pattern = str(day_dir / SEGMENT_FILENAME_PATTERN)
        cmd = [
            "rtsp-record",
            "-v",  # need verbose so it forwards ffmpeg's stderr through to us
            "-d", str(self.cfg["schedule"]["segment_duration"]),
            "-o", pattern,
            self.cam.rtsp_url or "",
        ]
        logger.info("[%s] starting rtsp-record into %s", self.cam.name, day_dir)
        # Redact creds in case proxy.mode is "direct" (URL hits the cam
        # directly with embedded user:pass).
        logger.debug("[%s] exec: %s", self.cam.name,
                     _redact_url(" ".join(shlex.quote(x) for x in cmd)))
        self.record_proc = subprocess.Popen(
            cmd, stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL, stderr=subprocess.PIPE,
            bufsize=1, universal_newlines=True,
        )
        self._record_started_at = time.monotonic()
        self._record_stderr_thread = threading.Thread(
            target=_pipe_stderr_to_logger,
            args=(self.record_proc, f"[{self.cam.name}] rtsp-record"),
            daemon=True,
        )
        self._record_stderr_thread.start()

    def _restart_recording(self) -> None:
        if self.record_proc and self.record_proc.poll() is None:
            self.record_proc.send_signal(signal.SIGINT)
            try:
                self.record_proc.wait(timeout=10)
            except subprocess.TimeoutExpired:
                self.record_proc.kill()
                self.record_proc.wait()
        if self._record_stderr_thread:
            self._record_stderr_thread.join(timeout=2)
            self._record_stderr_thread = None
        self._start_recording_for_today()

    def _start_playback(self) -> None:
        cfg = self.cfg["playback"]
        cmd = ["rtsp-play",
               "--player", cfg["player"],
               "--transport", cfg["transport"]]
        if cfg["no_audio"]:
            cmd.append("--no-audio")
        cmd.append(self.cam.rtsp_url or "")
        logger.info("[%s] starting rtsp-play (%s)", self.cam.name, cfg["player"])
        try:
            self.play_proc = subprocess.Popen(cmd, stdin=subprocess.DEVNULL)
        except OSError as e:
            logger.error("[%s] failed to start rtsp-play: %s", self.cam.name, e)
            self.play_proc = None

    def _do_rotation(self) -> None:
        """End-of-day: stop record, optionally merge, start fresh record."""
        previous_day = self._current_day
        previous_dir = self._current_dir
        if self.record_proc and self.record_proc.poll() is None:
            logger.info("[%s] rotating: stopping rtsp-record", self.cam.name)
            self.record_proc.send_signal(signal.SIGINT)
            try:
                self.record_proc.wait(timeout=15)
            except subprocess.TimeoutExpired:
                logger.warning("[%s] rtsp-record did not exit on SIGINT; killing",
                               self.cam.name)
                self.record_proc.kill()
                self.record_proc.wait()
        if self._record_stderr_thread:
            self._record_stderr_thread.join(timeout=2)
            self._record_stderr_thread = None
        self._start_recording_for_today()

        if self.cfg["schedule"]["merge_on_rotate"] and previous_dir and previous_day:
            try:
                segs = _segment_files_in(previous_dir)
                if segs:
                    out = previous_dir / MERGED_FILENAME_TEMPLATE.format(date=previous_day)
                    logger.info("[%s] merging %d segment(s) for %s",
                                self.cam.name, len(segs), previous_day)
                    merge_segments(segs, out)
                    if self.cfg["schedule"]["delete_segments_after_merge"]:
                        for s in segs:
                            try:
                                s.unlink()
                            except OSError as e:
                                logger.warning("[%s] could not delete %s: %s",
                                               self.cam.name, s, e)
                else:
                    logger.warning("[%s] nothing to merge for %s", self.cam.name, previous_day)
            except Exception:
                logger.exception("[%s] merge for %s failed", self.cam.name, previous_day)

    def _stop_subprocesses(self) -> None:
        with self._shutdown_lock:
            if self._stopped:
                return
            self._stopped = True
            for label, proc in (("rtsp-record", self.record_proc),
                                ("rtsp-play", self.play_proc)):
                if proc and proc.poll() is None:
                    logger.info("[%s] stopping %s", self.cam.name, label)
                    try:
                        proc.send_signal(signal.SIGINT)
                    except ProcessLookupError:
                        continue
                    try:
                        proc.wait(timeout=15)
                    except subprocess.TimeoutExpired:
                        logger.warning("[%s] %s did not exit; killing",
                                       self.cam.name, label)
                        proc.kill()
                        proc.wait()
            if self._record_stderr_thread:
                self._record_stderr_thread.join(timeout=2)
                self._record_stderr_thread = None
            self.record_proc = None
            self.play_proc = None


# ---------------------------------------------------------------------------
# Subprocess stderr → logger plumbing
# ---------------------------------------------------------------------------

def _pipe_stderr_to_logger(proc: subprocess.Popen, prefix: str,
                           level: int = logging.WARNING) -> None:
    """Forward each line from `proc.stderr` to the nvrd logger with `prefix`.

    Without this, all of rtsp-record's diagnostic output (and ffmpeg's behind
    it) is silently dropped on the floor — a permanent fail (auth, codec,
    bad URL) shows up only as 'rtsp-record exited (rc=4)' in nvrd's log,
    forcing you to rerun the command by hand to find out why.
    """
    if proc.stderr is None:
        return
    try:
        for raw in proc.stderr:
            line = raw.rstrip()
            if not line:
                continue
            # Some lines are noisy progress (e.g. ffmpeg's frame= bitrate=);
            # log them at INFO so users can grep them out, errors at WARNING.
            # Heuristic: if the line carries an obvious failure marker, lift
            # it to WARNING; otherwise INFO is enough.
            line_low = line.lower()
            if ("error" in line_low or "fail" in line_low
                    or "denied" in line_low or "unauthorized" in line_low):
                logger.warning("%s: %s", prefix, line)
            else:
                logger.info("%s: %s", prefix, line)
    except (OSError, ValueError):
        # Pipe closed mid-read — process exited. Nothing more to do.
        return


# ---------------------------------------------------------------------------
# Filesystem helpers
# ---------------------------------------------------------------------------

_SEGMENT_RE = re.compile(r"^cam-\d{4}-\d{2}-\d{2}_\d{2}-\d{2}-\d{2}\.mkv$")


def _segment_files_in(folder: Path) -> List[Path]:
    if not folder.is_dir():
        return []
    return sorted(p for p in folder.iterdir()
                  if p.is_file() and _SEGMENT_RE.match(p.name))


def _latest_segment(folder: Path) -> Optional[Path]:
    segs = _segment_files_in(folder)
    return segs[-1] if segs else None


# ---------------------------------------------------------------------------
# Rotation timing
# ---------------------------------------------------------------------------

def parse_rotate_at(text: str) -> Tuple[int, int]:
    h, m = (int(x) for x in text.split(":"))
    return h, m


def next_rotation_after(now: _dt.datetime, hour: int, minute: int) -> _dt.datetime:
    """Return the next datetime at HH:MM after `now`.

    `now` is naive local time. On DST transition days the duration to the
    next rotation can be ±1 hour off, but the wall-clock time is honoured
    (which is what users want — "rotate at midnight" should rotate at
    whatever the wall clock calls midnight).
    """
    candidate = now.replace(hour=hour, minute=minute, second=0, microsecond=0)
    if candidate <= now:
        candidate += _dt.timedelta(days=1)
    return candidate


# ---------------------------------------------------------------------------
# Orchestrator
# ---------------------------------------------------------------------------

class Orchestrator:
    def __init__(self, cfg: Dict[str, Any]):
        self.cfg = cfg
        self.stop_event = threading.Event()
        self.workers: List[CameraWorker] = []

    def install_signal_handlers(self) -> None:
        def handler(signum, frame):
            logger.info("received signal %s, shutting down", signum)
            self.stop_event.set()
        signal.signal(signal.SIGINT, handler)
        signal.signal(signal.SIGTERM, handler)

    def gather_cameras(self) -> List[Camera]:
        disc = self.cfg["discovery"]
        auth = self.cfg["auth"]
        cams: List[Camera] = []

        if disc["mode"] == "static":
            entries = list(disc.get("cameras") or [])
        else:
            urls = discover_devices(disc["timeout"])
            if not urls:
                logger.warning("onvif-discover found no devices on the LAN")
                return []
            entries = []
            # Allow per-URL overrides from the static cameras list, even in
            # auto mode — useful when you want to set a name/credentials for
            # one specific known device but still benefit from autodiscover
            # for the rest.
            overrides = {c["device_url"]: c
                         for c in (disc.get("cameras") or [])
                         if isinstance(c, dict) and c.get("device_url")}
            for url in urls:
                entry = overrides.get(url, {})
                entries.append({"device_url": url, **entry})

        for entry in entries:
            url = entry.get("device_url")
            if not url:
                logger.warning("skipping camera entry with no device_url: %r", entry)
                continue
            cams.append(Camera(
                name=entry.get("name") or _safe_name_from_url(url),
                device_url=url,
                user=entry.get("user", auth["user"]) or "",
                password=entry.get("password", auth["password"]) or "",
                inject_credentials=entry.get("inject_credentials",
                                             auth["inject_credentials"]),
            ))
        return cams

    def _resupervise(self, supervisor: "Go2rtcSupervisor",
                     cams: List[Camera]) -> None:
        """Re-resolve the RTSP URL for every cam and bounce go2rtc with the
        fresh config.

        Workers keep using their stable `rtsp://127.0.0.1:8554/<cam-name>`
        URL — only what go2rtc points UPSTREAM gets refreshed. Resolution
        runs against `cam.device_url` (the ONVIF service URL we discovered
        at startup) which doesn't move when the media URL behind it does.
        """
        proxy_cams = []
        for cam in cams:
            try:
                fresh = resolve_rtsp_url(cam, self.cfg["auth"]["timeout"])
                logger.info("[%s] re-resolved -> %s",
                            cam.name, _redact_url(fresh))
                proxy_cams.append(dataclasses.replace(cam, rtsp_url=fresh))
            except Exception as e:
                logger.error("[%s] re-resolve failed: %s; "
                             "go2rtc will keep its previous URL for this cam",
                             cam.name, e)
                # Preserve whatever the supervisor knew before.
                for prev in supervisor.cams:
                    if prev.name == cam.name:
                        proxy_cams.append(prev)
                        break
        supervisor.set_cams(proxy_cams)
        supervisor.restart()

    def resolve_all(self, cams: List[Camera]) -> List[Camera]:
        ok: List[Camera] = []
        for cam in cams:
            try:
                cam.rtsp_url = resolve_rtsp_url(cam, self.cfg["auth"]["timeout"])
                # Redact userinfo so the log doesn't carry the password in
                # cleartext (it's there when inject_credentials is on).
                logger.info("resolved %s -> %s", cam.name, _redact_url(cam.rtsp_url))
                ok.append(cam)
            except Exception as e:
                logger.error("failed to resolve %s: %s", cam.name, e)
        return ok

    def run(self) -> int:
        _check_leaf_scripts_in_path()
        if self.cfg["proxy"]["mode"] == "proxy":
            _check_go2rtc_in_path()

        cams = self.resolve_all(self.gather_cameras())
        if not cams:
            logger.error("no cameras resolved; nothing to do")
            return EXIT_PROTOCOL

        base = Path(self.cfg["storage"]["base_dir"]).expanduser()
        if not base.is_dir():
            logger.error("storage.base_dir does not exist: %s", base)
            return EXIT_USAGE

        supervisor: Optional[Go2rtcSupervisor] = None
        if self.cfg["proxy"]["mode"] == "proxy":
            supervisor = Go2rtcSupervisor(cams, self.cfg)
            supervisor.start()
            if not supervisor.wait_ready():
                supervisor.stop()
                return EXIT_PROTOCOL
            # Swap each cam's RTSP URL to the local proxy. The original cam
            # URL is kept in cam.device_url; logs that need it use the name.
            for cam in cams:
                local = supervisor.local_url_for(cam)
                logger.info("[%s] proxying via %s", cam.name, local)
                cam.rtsp_url = local

        for cam in cams:
            w = CameraWorker(cam, self.cfg, self.stop_event)
            self.workers.append(w)
            w.start()

        rotate_h, rotate_m = parse_rotate_at(self.cfg["schedule"]["rotate_at"])
        next_rot = next_rotation_after(_dt.datetime.now(), rotate_h, rotate_m)
        logger.info("next rotation: %s", next_rot.isoformat(timespec="seconds"))

        try:
            while not self.stop_event.is_set():
                now = _dt.datetime.now()
                if now >= next_rot:
                    logger.info("rotation tick at %s", now.isoformat(timespec="seconds"))
                    for w in self.workers:
                        w.request_rotation()
                    next_rot = next_rotation_after(now + _dt.timedelta(seconds=1),
                                                   rotate_h, rotate_m)
                    logger.info("next rotation: %s",
                                next_rot.isoformat(timespec="seconds"))
                if supervisor and not supervisor.is_alive():
                    # Don't blindly restart with the previous /tmp config:
                    # if the cam URL changed (DHCP, reboot, port change),
                    # the old URL is dead and go2rtc would loop trying to
                    # reach it. Re-run discovery+resolve first, swap the
                    # cam list, then restart go2rtc with a fresh config.
                    logger.warning("go2rtc died, re-resolving cameras and restarting")
                    self._resupervise(supervisor, cams)
                self.stop_event.wait(timeout=10)
        finally:
            logger.info("stopping %d worker(s)", len(self.workers))
            for w in self.workers:
                w.shutdown()
            for w in self.workers:
                w.join(timeout=20)
            if supervisor:
                supervisor.stop()
        return EXIT_OK


