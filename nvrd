# Leaf scripts we shell out to. They must all be in PATH.
LEAF_SCRIPTS = (
    "onvif-discover",
    "onvif-rtsp",
    "rtsp-record",
    "rtsp-play",
    "footage-merge",
)

# Tags used in fixed file/folder names. Kept here so tests can reference them.
SEGMENT_FILENAME_PATTERN = "cam-%Y-%m-%d_%H-%M-%S.mkv"
MERGED_FILENAME_TEMPLATE = "_merged-{date}.mkv"
DATE_FOLDER_FORMAT = "%Y-%m-%d"


# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

logger = logging.getLogger(PROG)


def _setup_logging(level_name: str, file_path: Optional[str]) -> None:
    level = getattr(logging, level_name.upper(), logging.INFO)
    logger.setLevel(level)
    fmt = logging.Formatter(
        fmt="%(asctime)s [%(levelname)s] %(name)s: %(message)s",
        datefmt="%Y-%m-%d %H:%M:%S",
    )
    # Stdout handler: always on. Logs go to stdout, not stderr, because the
    # user explicitly asked for stdout.
    stdout_h = logging.StreamHandler(sys.stdout)
    stdout_h.setFormatter(fmt)
    logger.addHandler(stdout_h)
    if file_path:
        path = os.path.expanduser(file_path)
        os.makedirs(os.path.dirname(path) or ".", exist_ok=True)
        file_h = logging.handlers.RotatingFileHandler(
            path, maxBytes=10 * 1024 * 1024, backupCount=5,
        )
        file_h.setFormatter(fmt)
        logger.addHandler(file_h)


