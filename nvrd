# CLI
# ---------------------------------------------------------------------------

def _default_config_path() -> str:
    """Return the default config-file path, honouring XDG_CONFIG_HOME.

    Falls back to `~/.config/onvif-nvr/config.yaml` when XDG_CONFIG_HOME is
    unset (the freedesktop spec's documented behaviour).
    """
    base = os.environ.get("XDG_CONFIG_HOME") or os.path.expanduser("~/.config")
    return os.path.join(base, "onvif-nvr", "config.yaml")


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog=PROG,
        description="Long-running orchestrator for the onvif-nvr-toolkit "
                    "(discovers cameras, records continuously in segments, "
                    "rotates and merges daily).",
        add_help=False,
    )
    default_cfg = _default_config_path()
    p.add_argument("-c", "--config", default=default_cfg, metavar="FILE",
                   help=f"path to YAML config (default: {default_cfg}; pass /dev/null "
                        "to run with built-in defaults only)")
    p.add_argument("--check", action="store_true",
                   help="validate config + dependencies + camera resolution, "
                        "then exit without recording")
    p.add_argument("-v", "--verbose", action="store_true",
                   help="bump log level to DEBUG (overrides config)")
    p.add_argument("-V", "--version", action="store_true",
                   help="print version and exit")
    p.add_argument("-h", "--help", action="store_true",
                   help="show this help and exit")
    return p


def main(argv=None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)

    if args.help:
        parser.print_help()
        return EXIT_OK
    if args.version:
        print(f"{PROG} {VERSION}")
        return EXIT_OK

    cfg_path = args.config
    if cfg_path and not Path(os.path.expanduser(cfg_path)).is_file():
        # No config file present: silently fall back to defaults so the
        # user can run `nvrd --check` to see what's missing.
        cfg = load_config(None)
    else:
        cfg = load_config(cfg_path)

    log_level = "debug" if args.verbose else cfg["logging"]["level"]
    _setup_logging(log_level, cfg["logging"].get("file"))

    logger.info("nvrd %s starting", VERSION)
    if cfg_path:
        logger.info("config: %s", cfg_path)

    orch = Orchestrator(cfg)

    if args.check:
        try:
            _check_leaf_scripts_in_path()
            if cfg["proxy"]["mode"] == "proxy":
                _check_go2rtc_in_path()
            cams = orch.resolve_all(orch.gather_cameras())
            mode = cfg["proxy"]["mode"]
            logger.info("check OK: %d camera(s) resolved (proxy.mode=%s)",
                        len(cams), mode)
            return EXIT_OK if cams else EXIT_PROTOCOL
        except SystemExit as e:
            logger.error(str(e).removeprefix(f"{PROG}: "))
            return EXIT_USAGE

    orch.install_signal_handlers()
    try:
        return orch.run()
    except KeyboardInterrupt:
        logger.info("interrupted")
        return EXIT_INTERRUPT


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(EXIT_INTERRUPT)
